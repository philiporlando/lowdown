# --- Location to monitor (default: downtown Portland, OR) ---
LD_APARTMENT_LAT=45.5152
LD_APARTMENT_LON=-122.6784

# How far out to watch, in meters ("earshot"). 3000 m ~= 1.9 mi.
LD_EARSHOT_RADIUS_M=3000

# --- Rule threshold ---
# 14 CFR 91.119(b): over congested areas, 1000 ft above the highest obstacle
# within 2000 ft. We approximate with height above terrain (AGL).
LD_THRESHOLD_AGL_FT=1000
# Optional pad added to the threshold to roughly account for buildings/obstacles.
LD_OBSTACLE_BUFFER_FT=0

# --- Polling ---
# Seconds between OpenSky queries. 30s keeps you within the free credit budget.
LD_POLL_INTERVAL_S=30
# Seconds of silence before an ongoing low-altitude "event" is closed.
LD_EVENT_GAP_S=300

# --- Map viewport (on-demand) live queries ---
# The map fetches whatever box you're looking at; these bound the OpenSky cost.
# Oversized viewports are shrunk toward their center to this many square degrees.
LD_VIEW_MAX_AREA_DEG2=16
# Reuse a recent viewport fetch for this many seconds (repeated polls / small pans).
LD_VIEW_CACHE_TTL_S=12

# --- OpenSky Network credentials (recommended) ---
# Create a free account, then an API client, at https://opensky-network.org/
# Leave blank to use heavily rate-limited anonymous access.
LD_OPENSKY_CLIENT_ID=
LD_OPENSKY_CLIENT_SECRET=

# --- Terrain elevation (for AGL) ---
# "open-meteo" queries the free Open-Meteo elevation API and caches results.
# "fixed" just uses LD_DEFAULT_GROUND_ELEVATION_M everywhere.
LD_ELEVATION_PROVIDER=open-meteo
LD_DEFAULT_GROUND_ELEVATION_M=15
LD_ELEVATION_GRID_DEG=0.005

# --- Approach/departure annotation ---
# Events near these airports (or with a steep climb/descent) are annotated as
# "likely approach/departure", which is legally EXEMPT from 91.119 minimums.
LD_AIRPORT_PROXIMITY_KM=8
LD_VERTICAL_RATE_EXCEPTED_FPM=500

# --- Storage / runtime ---
LD_DB_URL=sqlite:///data/lowdown.db
LD_RUN_COLLECTOR=true
